---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE, PRODUCTS } from '../../config';

export function getStaticPaths() {
  return PRODUCTS.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const marketplaces = [
  { label: 'BUY ON TOKOPEDIA', href: product.links.tokopedia, channel: 'tokopedia' },
  { label: 'BUY ON SHOPEE', href: product.links.shopee, channel: 'shopee' },
  { label: 'BUY ON TIKTOK SHOP', href: product.links.tiktok, channel: 'tiktok' },
];

const sizes = product.sizes ?? ['S', 'M', 'L', 'XL'];
const waNumber = SITE.whatsapp;
const waBaseText = `Halo ${SITE.name}! Mau order: ${product.name.toUpperCase()} ${product.code} — ${product.type}`;
---

<Base
  title={`${product.name.toUpperCase()} ${product.code} — ${product.type} | ${SITE.name}`}
  description={`${product.name.toUpperCase()} ${product.code} — ${product.type}. ${product.subtitle}. ${SITE.name} Archive Record.`}
>
  <Header variant="product" />

  <main
    class="flex-grow pt-28 pb-12 flex flex-col z-10 w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop"
  >
    <div
      class="flex-grow grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 auto-rows-min border border-outline-variant bg-surface-container-lowest"
    >
      <!-- Header Section -->
      <div
        class="col-span-1 md:col-span-2 lg:col-span-12 border-b border-outline-variant p-6 md:p-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-8 bg-surface/50"
      >
        <div>
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mb-4 block">
            Archive Record // {product.code}
          </p>
          <h2
            class="text-[56px] md:text-display-xl text-primary uppercase leading-none font-display-xl tracking-tighter"
            style='font-family: "Cloister Black", serif;'
          >
            {product.name}<br />{product.code}
          </h2>
        </div>
        <div class="md:text-right">
          <p class="font-label-mono text-label-mono text-primary/80 tracking-[0.2em] uppercase">
            {product.type}
          </p>
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest mt-2 uppercase">
            {product.subtitle}
          </p>
          <p
            id="stock-indicator"
            data-slug={product.slug}
            class="font-label-mono text-xs tracking-[0.2em] mt-4 uppercase hidden"
          ></p>
        </div>
      </div>

      <!-- Technical Imagery -->
      <div
        class="col-span-1 md:col-span-1 lg:col-span-7 border-b md:border-b-0 md:border-r border-outline-variant bg-background overflow-hidden relative min-h-[400px] md:min-h-[500px] flex items-center justify-center p-8 cursor-zoom-in"
        data-zoom-container
      >
        <img
          src={product.image}
          alt={`${product.name.toUpperCase()} ${product.code} — ${product.type} technical sheet`}
          class="w-full h-full object-contain will-change-transform"
          data-zoom
          draggable="false"
        />
      </div>

      <!-- Details & Purchasing -->
      <div class="col-span-1 md:col-span-1 lg:col-span-5 flex flex-col bg-surface-container-lowest">
        <!-- Marketplace Links (isi link-nya di src/config.ts) -->
        <div id="purchase" class="flex-grow flex flex-col bg-background">
          {
            waNumber && (
              <>
                <!-- Size picker -->
                <div class="p-6 border-b border-outline-variant flex flex-col gap-4" data-size-section>
                  <span class="font-label-mono text-[10px] text-primary/50 uppercase tracking-widest" data-i18n="select_size">
                    Select Size
                  </span>
                  <div class="flex flex-wrap gap-2">
                    {sizes.map((size) => (
                      <button
                        type="button"
                        data-size={size}
                        class="font-label-mono text-xs border border-outline-variant px-5 py-2.5 text-primary/70 hover:border-primary hover:text-primary transition-colors uppercase tracking-widest"
                      >
                        {size}
                      </button>
                    ))}
                  </div>
                </div>

                <!-- ORDER VIA WHATSAPP (paling atas) -->
                <a
                  class="group flex items-center justify-between p-6 border-b border-outline-variant bg-primary text-on-primary hover:bg-background hover:text-primary transition-colors"
                  href={`https://wa.me/${waNumber}?text=${encodeURIComponent(waBaseText)}`}
                  target="_blank"
                  rel="noopener"
                  data-buy-link
                  data-channel="whatsapp"
                  data-wa-order
                  data-wa-number={waNumber}
                  data-wa-base={waBaseText}
                >
                  <span class="font-label-mono text-xs tracking-widest uppercase" data-i18n="order_wa">
                    ORDER DIRECT — WHATSAPP
                  </span>
                  <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">
                    arrow_outward
                  </span>
                </a>
              </>
            )
          }
          {
            marketplaces.map((mp, i) => (
              <a
                class:list={[
                  'group flex items-center justify-between p-6 hover:bg-surface-variant transition-colors',
                  i < marketplaces.length - 1 && 'border-b border-outline-variant',
                ]}
                href={mp.href}
                target="_blank"
                rel="noopener"
                data-buy-link
                data-channel={mp.channel}
              >
                <span class="font-label-mono text-xs text-primary tracking-widest uppercase" data-buy-label data-i18n={`buy_${mp.channel}`}>{mp.label}</span>
                <span class="material-symbols-outlined text-primary text-sm transition-transform group-hover:translate-x-1">
                  arrow_forward
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<script>
  import { jsStrings, getLang } from '../../i18n';

  // Ambil stock dari API, tampilkan angka / SOLD OUT, matikan tombol beli kalau habis
  const indicator = document.getElementById('stock-indicator');
  const slug = indicator?.dataset.slug;
  let stockValue: number | undefined;

  function renderStock() {
    if (!indicator || stockValue === undefined) return;
    const s = jsStrings[getLang()] ?? jsStrings.en;
    indicator.classList.remove('hidden');
    if (stockValue > 0) {
      indicator.textContent = `${s.stock}${stockValue}`;
      indicator.classList.add('text-primary/80');
      indicator.classList.remove('text-error');
    } else {
      indicator.textContent = s.soldOut;
      indicator.classList.add('text-error');
      indicator.classList.remove('text-primary/80');
      document.querySelectorAll('[data-buy-link], [data-size-section]').forEach((el) => {
        el.classList.add('pointer-events-none', 'opacity-30');
        if (el.hasAttribute('href')) el.removeAttribute('href');
      });
    }
  }

  if (indicator && slug) {
    fetch('/api/stock')
      .then((r) => r.json())
      .then((data) => {
        stockValue = data[slug]; // undefined = belum di-set admin → gak nampilin apa-apa
        renderStock();
      })
      .catch(() => {});
  }
  document.addEventListener('langchange', renderStock);

  // Zoom lensa: area di bawah cursor diperbesar (cuma device yang punya hover/mouse)
  const zoomContainer = document.querySelector<HTMLElement>('[data-zoom-container]');
  const zoomImg = document.querySelector<HTMLElement>('[data-zoom]');
  if (zoomContainer && zoomImg && window.matchMedia('(hover: hover)').matches) {
    const ZOOM = 2.2;
    zoomContainer.addEventListener('mousemove', (e) => {
      const r = zoomImg.getBoundingClientRect();
      const x = Math.max(0, Math.min(100, ((e.clientX - r.left) / r.width) * 100));
      const y = Math.max(0, Math.min(100, ((e.clientY - r.top) / r.height) * 100));
      zoomImg.style.transformOrigin = `${x}% ${y}%`;
      zoomImg.style.transform = `scale(${ZOOM})`;
    });
    zoomContainer.addEventListener('mouseleave', () => {
      zoomImg.style.transform = 'scale(1)';
    });
  }

  // Size picker → update pesan WhatsApp sesuai size yang dipilih
  const waOrder = document.querySelector<HTMLAnchorElement>('[data-wa-order]');
  const sizeBtns = document.querySelectorAll<HTMLButtonElement>('[data-size]');
  let selectedSize = '';

  function updateWaHref() {
    if (!waOrder || !waOrder.dataset.waNumber) return;
    const text = `${waOrder.dataset.waBase}${selectedSize ? ` (Size ${selectedSize})` : ''}`;
    waOrder.href = `https://wa.me/${waOrder.dataset.waNumber}?text=${encodeURIComponent(text)}`;
  }

  sizeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      selectedSize = btn.dataset.size!;
      sizeBtns.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('bg-primary', active);
        b.classList.toggle('text-on-primary', active);
        b.classList.toggle('border-primary', active);
        b.classList.toggle('text-primary/70', !active);
        b.classList.toggle('border-outline-variant', !active);
      });
      updateWaHref();
    });
  });

  // Catat klik tombol beli (sendBeacon biar tetap kekirim walau pindah halaman)
  document.querySelectorAll<HTMLAnchorElement>('[data-buy-link]').forEach((link) => {
    link.addEventListener('click', () => {
      if (!link.href) return;
      const payload = JSON.stringify({ product: slug, channel: link.dataset.channel });
      navigator.sendBeacon('/api/clicks', new Blob([payload], { type: 'application/json' }));
    });
  });
</script>
