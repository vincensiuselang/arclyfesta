---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE, PRODUCTS, NEXT_RECORD } from '../config';
---

<Base title={`${SITE.name} — Dark Archive`}>
  <Header variant="home" />

  <main class="flex-grow pt-20 flex flex-col z-10 w-full">
    <!-- Hero -->
    <section
      class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop flex flex-col py-16 md:py-24"
    >
      <img
        src="/assets/wordmark.png"
        alt={`${SITE.name} — EST 2024`}
        class="w-full max-w-[1320px] h-auto object-contain self-start mb-10"
      />
      <p class="font-label-mono text-sm md:text-base text-primary/50 tracking-widest uppercase mb-6 block">
        Archive // EST. {SITE.est}
      </p>
      <!-- <h1
        class="text-[56px] leading-[1.05] md:text-display-xl text-primary uppercase font-display-xl tracking-tighter max-w-5xl"
      >
        The<br />Archive<br />Beyond
      </h1> -->
      <p class="font-body-md text-body-md text-primary/60 mt-10 max-w-md">
        "The archive begins with Record 0000. Everything after is another entry."
      </p>
      <div class="mt-12">
        <a
          href="#archive"
          class="inline-flex items-center gap-3 bg-primary text-on-primary font-label-mono text-xs tracking-widest uppercase px-8 py-4 border border-primary hover:bg-background hover:text-primary transition-colors duration-300"
        >
          View Archive
          <span class="material-symbols-outlined text-sm">arrow_downward</span>
        </a>
      </div>
    </section>

    <!-- Archive / Products -->
    <section
      id="archive"
      class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap"
    >
      <div class="border border-outline-variant bg-surface-container-lowest">
        <!-- Section Header -->
        <div
          class="border-b border-outline-variant p-6 md:p-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-8 bg-surface/50"
        >
          <div>
            <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mb-4 block">
              Index // Records
            </p>
            <h2 class="text-headline-lg-mobile md:text-headline-lg text-primary uppercase font-headline-lg">
              Arcticle 0000
            </h2>
          </div>
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase md:text-right">
            0000 Arclyfesta Released
          </p>
        </div>

        <!-- Records Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12">
          {
            PRODUCTS.map((product) => (
              <a
                href={`/products/${product.slug}/`}
                class="group col-span-1 lg:col-span-7 border-b lg:border-b-0 lg:border-r border-outline-variant bg-background hover:bg-surface-container-low transition-colors duration-300 flex flex-col"
              >
                <div class="overflow-hidden relative min-h-[360px] md:min-h-[480px] flex items-center justify-center p-8">
                  <img
                    src={product.image}
                    alt={`${product.name.toUpperCase()} ${product.code} — ${product.type}`}
                    class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
                  />
                </div>
                <div class="border-t border-outline-variant p-6 flex items-center justify-between">
                  <div>
                    <p class="font-label-mono text-xs text-primary tracking-widest uppercase">
                      {product.name} {product.code} — {product.type}
                    </p>
                    <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mt-2">
                      {product.subtitle}
                    </p>
                    <p
                      data-stock-badge={product.slug}
                      class="font-label-mono text-[10px] tracking-[0.2em] uppercase mt-2 hidden"
                    ></p>
                  </div>
                  <span class="material-symbols-outlined text-primary text-sm transition-transform group-hover:translate-x-1">
                    arrow_forward
                  </span>
                </div>
              </a>
            ))
          }

          <!-- Next Record (coming soon) -->
          <div
            class="col-span-1 lg:col-span-5 bg-surface-container-lowest flex flex-col items-center justify-center gap-4 min-h-[240px] lg:min-h-0 p-8"
          >
            <span
              class="font-label-mono text-[10px] text-primary/30 tracking-[0.3em] uppercase border border-outline-variant px-4 py-2"
            >
              {NEXT_RECORD}
            </span>
            <p class="font-label-mono text-[10px] text-primary/30 tracking-widest uppercase">Coming Soon</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Brand Statement -->
    <section class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap">
      <div class="max-w-2xl mx-auto text-center flex flex-col items-center">
        <p class="font-label-mono text-xl md:text-3xl text-primary tracking-[0.3em] uppercase">ARCLYFESTA</p>
        <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mt-2">Dark Archive</p>

        <div class="flex flex-col gap-4 mt-12 font-headline-lg text-primary/80 text-xl md:text-2xl leading-snug">
          <p>The archive is never complete.</p>
          <p>Every release is catalogued.</p>
          <p>Every garment is numbered.</p>
          <p>Nothing is reproduced exactly.</p>
          <p>Nothing exists outside the archive.</p>
        </div>

        <p class="text-headline-lg-mobile md:text-headline-lg text-primary font-headline-lg leading-tight mt-12">
          The Archive Begins.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  // Badge stock di kartu produk homepage
  fetch('/api/stock')
    .then((r) => r.json())
    .then((data) => {
      document.querySelectorAll<HTMLElement>('[data-stock-badge]').forEach((badge) => {
        const stock = data[badge.dataset.stockBadge!];
        if (stock === undefined) return;
        badge.classList.remove('hidden');
        if (stock > 0) {
          badge.textContent = `STOCK: ${stock}`;
          badge.classList.add('text-primary/60');
        } else {
          badge.textContent = 'SOLD OUT';
          badge.classList.add('text-error');
        }
      });
    })
    .catch(() => {});
</script>
