---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';
import { SITE, PRODUCTS, NEXT_RECORD } from '../config';
---

<Base title={`${SITE.name} — Dark Archive`}>
  <Header variant="home" />

  <main class="flex-grow pt-20 flex flex-col z-10 w-full">
    <!-- Hero -->
    <section
      class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop flex flex-col py-16 md:py-24"
    >
      <img
        src="/assets/wordmark.png"
        alt={`${SITE.name} — EST 2024`}
        class="w-full max-w-[1320px] h-auto object-contain self-start mb-10"
      />
      <p class="font-label-mono text-sm md:text-base text-primary/50 tracking-widest uppercase mb-6 block">
        Archive // EST. {SITE.est}
      </p>
      <!-- <h1
        class="text-[56px] leading-[1.05] md:text-display-xl text-primary uppercase font-display-xl tracking-tighter max-w-5xl"
      >
        The<br />Archive<br />Beyond
      </h1> -->
      <p class="font-body-md text-body-md text-primary/60 mt-10 max-w-md">
        <span data-i18n="hero_quote">"The archive begins with Record 0000. Everything after is another entry."</span>
      </p>
      <div class="mt-12">
        <a
          href="#archive"
          class="inline-flex items-center gap-3 bg-primary text-on-primary font-label-mono text-xs tracking-widest uppercase px-8 py-4 border border-primary hover:bg-background hover:text-primary transition-colors duration-300"
        >
          <span data-i18n="view_archive">View Archive</span>
          <span class="material-symbols-outlined text-sm">arrow_downward</span>
        </a>
      </div>
    </section>

    <Marquee />

    <!-- Archive / Products -->
    <section
      id="archive"
      class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap"
    >
      <div class="border border-outline-variant bg-surface-container-lowest">
        <!-- Section Header -->
        <div
          class="border-b border-outline-variant p-6 md:p-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-8 bg-surface/50"
        >
          <div>
            <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mb-4 block">
              Index // Records
            </p>
            <h2 class="text-headline-lg-mobile md:text-headline-lg text-primary uppercase font-headline-lg">
              Arcticle 0000
            </h2>
          </div>
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase md:text-right">
            0000 Arclyfesta Released
          </p>
        </div>

        <!-- Records Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12">
          {
            PRODUCTS.map((product) => (
              <a
                href={`/products/${product.slug}/`}
                class="group col-span-1 lg:col-span-7 border-b lg:border-b-0 lg:border-r border-outline-variant bg-background hover:bg-surface-container-low transition-colors duration-300 flex flex-col"
              >
                <div class="overflow-hidden relative min-h-[360px] md:min-h-[480px] flex items-center justify-center p-8">
                  <img
                    src={product.imageCard ?? product.image}
                    alt={`${product.name.toUpperCase()} ${product.code} — ${product.type}`}
                    class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
                  />
                </div>
                <div class="border-t border-outline-variant p-6 flex items-center justify-between">
                  <div>
                    <p class="font-label-mono text-xs text-primary tracking-widest uppercase">
                      {product.name} {product.code} — {product.type}
                    </p>
                    <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mt-2">
                      {product.subtitle}
                    </p>
                    <p
                      data-stock-badge={product.slug}
                      class="font-label-mono text-[10px] tracking-[0.2em] uppercase mt-2 hidden"
                    ></p>
                  </div>
                  <span class="material-symbols-outlined text-primary text-sm transition-transform group-hover:translate-x-1">
                    arrow_forward
                  </span>
                </div>
              </a>
            ))
          }

          <!-- Next Record (coming soon) -->
          <div
            class="col-span-1 lg:col-span-5 bg-surface-container-lowest flex flex-col items-center justify-center gap-4 min-h-[240px] lg:min-h-0 p-8"
          >
            <span
              class="font-label-mono text-[10px] text-primary/30 tracking-[0.3em] uppercase border border-outline-variant px-4 py-2"
            >
              {NEXT_RECORD}
            </span>
            <p class="font-label-mono text-[10px] text-primary/30 tracking-widest uppercase" data-i18n="coming_soon">Coming Soon</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Brand Statement -->
    <section class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap">
      <div class="max-w-2xl mx-auto text-center flex flex-col items-center">
        <p class="font-label-mono text-xl md:text-3xl text-primary tracking-[0.3em] uppercase">ARCLYFESTA</p>
        <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mt-2">Dark Archive</p>

        <div class="flex flex-col gap-4 mt-12 font-headline-lg text-primary/80 text-xl md:text-2xl leading-snug">
          <p data-i18n="m1">Every archive starts with one record.</p>
          <p data-i18n="m2">Every release is catalogued.</p>
          <p data-i18n="m3">Every garment is numbered.</p>
          <p data-i18n="m4">Nothing is reproduced exactly.</p>
          <p data-i18n="m5">Nothing exists outside the archive.</p>
        </div>

        <p class="text-headline-lg-mobile md:text-headline-lg text-primary font-headline-lg leading-tight mt-12" data-i18n="archive_begins">
          The Archive Begins.
        </p>
      </div>
    </section>

    <!-- Join the Archive (email capture) -->
    <section class="w-full max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop pb-section-gap">
      <div class="max-w-xl mx-auto border border-outline-variant bg-surface-container-lowest p-8 md:p-12 flex flex-col gap-10">
        <div class="text-center">
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mb-3" data-i18n="join_label">Mailing List</p>
          <p class="text-headline-lg-mobile font-headline-lg text-primary uppercase" data-i18n="join_title">Join the Archive</p>
          <p class="font-label-mono text-[10px] text-primary/50 tracking-widest uppercase mt-3" data-i18n="join_sub">Be first when the next record drops</p>
        </div>
        <form id="subscribe-form" class="flex flex-col md:flex-row gap-6 md:gap-4 md:items-end" novalidate>
          <div class="flex-1 w-full flex flex-col gap-2">
            <label for="sub-email" class="font-label-mono text-[10px] text-primary/50 uppercase tracking-widest" data-i18n="join_email">Email Address</label>
            <input
              id="sub-email"
              type="email"
              autocomplete="email"
              class="bg-transparent border-0 border-b border-primary rounded-none px-0 py-2 font-label-mono text-sm text-primary focus:ring-0 focus:border-primary focus:outline-none w-full"
            />
          </div>
          <button
            type="submit"
            class="bg-primary text-on-primary font-label-mono text-xs tracking-widest uppercase px-8 py-4 border border-primary hover:bg-background hover:text-primary transition-colors duration-300"
            data-i18n="join_btn"
          >Submit</button>
        </form>
        <p id="subscribe-msg" class="font-label-mono text-[10px] tracking-widest uppercase text-center hidden"></p>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  import { jsStrings, getLang } from '../i18n';

  // Badge stock di kartu produk homepage
  let stockData: Record<string, number> = {};

  function renderBadges() {
    const s = jsStrings[getLang()] ?? jsStrings.en;
    document.querySelectorAll<HTMLElement>('[data-stock-badge]').forEach((badge) => {
      const stock = stockData[badge.dataset.stockBadge!];
      if (stock === undefined) return;
      badge.classList.remove('hidden');
      if (stock > 0) {
        badge.textContent = `${s.stock}${stock}`;
        badge.classList.add('text-primary/60');
        badge.classList.remove('text-error');
      } else {
        badge.textContent = s.soldOut;
        badge.classList.add('text-error');
        badge.classList.remove('text-primary/60');
      }
    });
  }

  fetch('/api/stock')
    .then((r) => r.json())
    .then((data) => {
      stockData = data;
      renderBadges();
    })
    .catch(() => {});
  document.addEventListener('langchange', renderBadges);

  // Form Join the Archive
  const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('sub-email') as HTMLInputElement | null;
  const msg = document.getElementById('subscribe-msg');
  let subStatus: 'ok' | 'err' | null = null;

  function renderSubMsg() {
    if (!msg || !subStatus) return;
    const s = jsStrings[getLang()] ?? jsStrings.en;
    msg.classList.remove('hidden');
    msg.textContent = subStatus === 'ok' ? s.subOk : s.subErr;
    msg.classList.toggle('text-error', subStatus === 'err');
    msg.classList.toggle('text-primary/70', subStatus === 'ok');
  }
  document.addEventListener('langchange', renderSubMsg);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim() ?? '';
    const res = await fetch('/api/subscribe', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ email }),
    }).catch(() => null);
    subStatus = res?.ok ? 'ok' : 'err';
    if (res?.ok && emailInput) emailInput.value = '';
    renderSubMsg();
  });
</script>
